{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*",
    "api/**/*",
    "server.ts",
    "vite.config.ts",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage",
    "cpanel-deploy",
    "cpanel-deploy-staging",
    "assets",
    "data",
    "storage",
    "server.cjs",
    "server.cjs.map",
    "**/*.min.js",
    "**/*.map"
  ]
}
