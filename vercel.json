{
  "rewrites": [
    {
      "source": "/api/shopee/callback",
      "destination": "/api/shopee/callback"
    },
    {
      "source": "/api/:path*",
      "destination": "https://quanly.linhkienamthanh.net/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
