# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Production URL (domain chính thức)
APP_URL=https://quanly.linhkienamthanh.net
API_BASE_URL=https://quanly.linhkienamthanh.net

# Frontend (Vercel): để TRỐNG → gọi /api/... relative (vercel.json proxy sang backend).
# Không set VITE_API_BASE_URL trên Vercel trừ khi gọi API cross-origin trực tiếp.
VITE_API_BASE_URL=

# --- Vercel Environment Variables (Dashboard → Settings → Environment Variables) ---
# APP_URL=https://quanly.linhkienamthanh.net
# API_BASE_URL=https://quanly.linhkienamthanh.net
# VITE_API_BASE_URL=          (để trống)
# ADMIN_USERNAME, ADMIN_PASSWORD, JWT_SECRET, GEMINI_API_KEY, SHOPEE_* (nếu cần trên serverless)
#
# Khi DNS quanly.linhkienamthanh.net trỏ sang Vercel:
# - Tạo subdomain backend (A record → IP cPanel), VD: api.quanly.linhkienamthanh.net
# - Vercel Env: CPANEL_BACKEND_URL=https://api.quanly.linhkienamthanh.net
# - KHÔNG dùng chính domain Vercel làm backend (gây loop, UI/API không cập nhật)

# Shopee Partner App — Redirect URL: https://quanly.linhkienamthanh.net/api/shopee/callback
# Shopee Partner App — Webhook URL:   https://quanly.linhkienamthanh.net/api/shopee/webhook

# ADMIN AUTHENTICATION (bắt buộc trên Vercel cho api/login.js)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password123"
JWT_SECRET="your_jwt_secret_key_change_me_in_production"

# SHOPEE OPEN PLATFORM (Partner API v2) — LIVE credentials only.
SHOPEE_ENV="live"
SHOPEE_PARTNER_ID="YOUR_LIVE_PARTNER_ID"
SHOPEE_PARTNER_KEY="YOUR_LIVE_PARTNER_KEY"
