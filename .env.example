# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Production URL (domain chính thức)
APP_URL=https://quanly.linhkienamthanh.net
API_BASE_URL=https://quanly.linhkienamthanh.net

# Frontend (Vercel): để TRỐNG → gọi /api/... relative (vercel.json proxy sang backend).
# Không set VITE_API_BASE_URL trên Vercel trừ khi gọi API cross-origin trực tiếp.
VITE_API_BASE_URL=

# --- Vercel (frontend + API proxy) ---
# CPANEL_BACKEND_URL=https://api.linhkienamthanh.net
# Bắt buộc tạo DNS trước: cPanel → Zone Editor → A record "api" → IP server hosting
# Login + auth/verify + đồng bộ Shopee đều proxy sang cPanel (JWT ký trên cPanel).
# Kiểm tra kết nối: GET https://quanly.linhkienamthanh.net/api/health/cpanel

# --- cPanel backend (bắt buộc cho đồng bộ Shopee) ---
# File .env hoặc Setup Node.js App → Environment Variables:
# SHOPEE_ENV=live
# SHOPEE_PARTNER_ID=1234567          (số nguyên Live từ open.shopee.com)
# SHOPEE_PARTNER_KEY=...             (Partner Key Live)
# SHOP_ID không set env — lưu trong Cài đặt app + data/shopee_tokens.json sau OAuth

# Shopee Partner App — Redirect URL (OAuth): https://quanly.linhkienamthanh.net/api/shopee/callback
# (Domain phải khớp Redirect URL Domain trên open.shopee.com — KHÔNG dùng api.*)
# Shopee Partner App — Webhook URL:   https://quanly.linhkienamthanh.net/api/shopee/webhook
# Shopee Verify yêu cầu POST → HTTP 2xx + body RỖNG (không JSON)
# Kiểm tra backend cPanel từ Vercel: GET /api/health/cpanel

# ADMIN AUTHENTICATION (cPanel backend — login proxy qua Vercel)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password123"
JWT_SECRET="your_jwt_secret_key_change_me_in_production"

# SHOPEE OPEN PLATFORM (Partner API v2) — LIVE credentials only.
SHOPEE_ENV="live"
SHOPEE_PARTNER_ID="YOUR_LIVE_PARTNER_ID"
SHOPEE_PARTNER_KEY="YOUR_LIVE_PARTNER_KEY"
