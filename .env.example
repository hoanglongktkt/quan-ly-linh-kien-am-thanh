# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Production URL (domain chính thức)
APP_URL=https://quanly.linhkienamthanh.net
API_BASE_URL=https://quanly.linhkienamthanh.net

# Frontend (Vercel): để TRỐNG → gọi /api/... relative (vercel.json proxy sang backend).
# Không set VITE_API_BASE_URL trên Vercel trừ khi gọi API cross-origin trực tiếp.
# Local: xem .env.development — VITE_API_BASE_URL= (relative localhost).
# CẢNH BÁO: mở quanly.linhkienamthanh.net = data PRODUCTION, không phải DB local đã xóa.
VITE_API_BASE_URL=

# --- Vercel (frontend + API proxy) ---
# CPANEL_BACKEND_URL=https://api.linhkienamthanh.net
# Bắt buộc — JWT_SECRET phải TRÙNG với cPanel (Setup Node.js / .htaccess):
# JWT_SECRET=251696
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=... (cùng mật khẩu đăng nhập trên cPanel backend)
# Login chạy local trên Vercel; đồng bộ Shopee proxy sang cPanel.

# --- cPanel backend (bắt buộc cho đồng bộ Shopee) ---
# File .env hoặc Setup Node.js App → Environment Variables:
# SHOPEE_ENV=live
# SHOPEE_PARTNER_ID=1234567          (số nguyên Live từ open.shopee.com)
# SHOPEE_PARTNER_KEY=...             (Partner Key Live)
# SHOP_ID không set env — lưu trong Cài đặt app + data/shopee_tokens.json sau OAuth

# Shopee Partner App — Redirect URL (OAuth): https://quanly.linhkienamthanh.net/api/shopee/callback
# (Domain phải khớp Redirect URL Domain trên open.shopee.com — KHÔNG dùng api.*)
# Shopee Partner App — Webhook URL:   https://quanly.linhkienamthanh.net/api/webhook/shopee
# Push API phải gọi trực tiếp Express backend để xác thực HMAC trên raw body.
# Kiểm tra backend cPanel từ Vercel: GET /api/health/cpanel

# ADMIN AUTHENTICATION (cPanel backend — login proxy qua Vercel)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password123"
JWT_SECRET="your_jwt_secret_key_change_me_in_production"

# SHOPEE OPEN PLATFORM (Partner API v2) — LIVE credentials only.
SHOPEE_ENV="live"
SHOPEE_PARTNER_ID="YOUR_LIVE_PARTNER_ID"
SHOPEE_PARTNER_KEY="YOUR_LIVE_PARTNER_KEY"
# Tùy chọn: token riêng do Shopee cấp cho Push API. Nếu không set, dùng SHOPEE_PARTNER_KEY.
SHOPEE_WEBHOOK_TOKEN=""
# Bật ghi trạng thái đơn từ webhook (mặc định tắt để giảm tải).
SHOPEE_WEBHOOK_ORDERS_ENABLED="1"

# MongoDB Atlas (products + channel_listings) — BẮT BUỘC trên cPanel để không mất data khi restart
# Dán Connection String từ Atlas → Database → Connect → Drivers
# Ví dụ: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/quanly?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/quanly?retryWrites=true&w=majority"
